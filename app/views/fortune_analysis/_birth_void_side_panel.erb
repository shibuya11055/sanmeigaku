<% panel_label = local_assigns.fetch(:panel_label, '宿命天中殺') %>

<aside class="birth-void-panel" data-birth-void-panel-target="panel" aria-hidden="true" aria-label="<%= panel_label %>の解説">
  <button type="button" class="birth-void-panel-close" data-action="birth-void-panel#close" aria-label="閉じる">
    <i class="fas fa-xmark"></i>
  </button>

  <div class="birth-void-panel-kicker"><%= panel_label %></div>
  <div class="birth-void-panel-heading">
    <span class="birth-void-panel-term" data-birth-void-panel-target="term"></span>
    <span class="birth-void-panel-category" data-birth-void-panel-target="category"></span>
  </div>

  <section class="birth-void-panel-section">
    <h3>概要</h3>
    <p data-birth-void-panel-target="short"></p>
  </section>

  <section class="birth-void-panel-section">
    <h3>詳細</h3>
    <p data-birth-void-panel-target="detail"></p>
  </section>
</aside>
