<aside class="rel-panel" data-relationship-panel-target="panel" aria-hidden="true" aria-label="位相用語の解説">
  <button type="button" class="rel-panel-close" data-action="relationship-panel#close" aria-label="閉じる">
    <i class="fas fa-xmark"></i>
  </button>

  <div class="rel-panel-kicker">位相用語</div>
  <div class="rel-panel-heading">
    <span class="rel-panel-term rel" data-relationship-panel-target="term"></span>
    <span class="rel-panel-category" data-relationship-panel-target="category"></span>
  </div>

  <section class="rel-panel-section">
    <h3>判定条件</h3>
    <p data-relationship-panel-target="short"></p>
  </section>

  <section class="rel-panel-section">
    <h3>意味と特徴</h3>
    <p data-relationship-panel-target="detail"></p>
  </section>
</aside>
