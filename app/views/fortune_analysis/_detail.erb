<div class="ultra-compact-detail" data-controller="natal-phase-panel">
  <div class="compact-section" data-controller="energy-panel">
    <div class="compact-header energy-bg"><i class="fas fa-star"></i> 三期エネルギー</div>
    <div class="compact-content">
      <span class="energy-item"><b>若年期</b>: <%= twelve_sub_star_button(youth_sub_star, 'youth') %>・<%= youth_sub_star.energy %></span>
      <span class="energy-item"><b>中年期</b>: <%= twelve_sub_star_button(middle_age_sub_star, 'middle') %>・<%= middle_age_sub_star.energy %></span>
      <span class="energy-item"><b>晩年期</b>: <%= twelve_sub_star_button(old_age_sub_star, 'old') %>・<%= old_age_sub_star.energy %></span>
    </div>
    <%= render 'fortune_analysis/energy_side_panel' %>
  </div>

  <% if abnormals.present? %>
    <div class="compact-section" data-controller="abnormal-panel">
      <div class="compact-header abnormal-bg"><i class="fas fa-exclamation-triangle"></i> 異常干支</div>
      <div class="compact-content">
        <% abnormals.each do |abnormal| %><%= abnormal_term_button(abnormal) %><% end %>
      </div>
      <%= render 'fortune_analysis/abnormal_side_panel' %>
    </div>
  <% end %>

  <% birth_void_values = birth_voids.values.compact %>
  <% if birth_void_values.present? %>
    <div class="compact-section" data-controller="birth-void-panel">
      <div class="compact-header void-bg"><i class="fas fa-ban"></i> 宿命天中殺</div>
      <div class="compact-content">
        <% birth_voids.each do |key, value| %>
          <% next if value.blank? %>
          <% void_class = css_classes({
            'tag-item': true,
            'text-center': has_birth_voids[:has_compatible_void] || has_birth_voids[:has_double_birth_void] || has_birth_voids[:has_complete_void],
            'color-red': value == '生日中殺' || value == '生月中殺' || value == '生年中殺' || value == '日座天中殺' || value == '日居天中殺',
            'green-circle': value == '互換中殺',
            'blue-square': value == '宿命二中殺',
            'complete-void-color': value == '全天中殺'
          }) %>
          <%= birth_void_button(key, value, day_heavenly_void, void_class) %>
        <% end %>
      </div>
      <%= render 'fortune_analysis/birth_void_side_panel' %>
    </div>
  <% end %>

  <div class="compact-section" data-controller="beast-panel">
    <div class="compact-header beast-bg"><i class="fas fa-dragon"></i> 宿命五型</div>
    <div class="compact-content center"><%= beast_type_button(beast_type) %></div>
    <%= render 'fortune_analysis/beast_side_panel' %>
  </div>

  <% if !stem_unions.values.all? { |union| union[:result].nil? } %>
    <div class="compact-section" data-controller="relationship-panel">
      <div class="compact-header unions-bg"><i class="fas fa-link"></i> 干合</div>
      <div class="compact-content">
        <% stem_unions.each do |key, union| %>
          <% if union[:result].present? %>
            <div class="info-row"><b>【<%= union[:title] %>】:</b> <%= relationship_term_span('干合') %> <%= union[:before].join('・') %> → <%= union[:result].join('・') %></div>
          <% end %>
        <% end %>
      </div>
      <%= render 'fortune_analysis/relationship_side_panel' %>
    </div>
  <% end %>

  <% phase_method_text = PhaseMethodText.new %>

  <% if phase_method[:has_combined] %>
    <div class="compact-section">
      <div class="compact-header combined-bg"><i class="fas fa-plus-circle"></i> 位相（合法）</div>
      <div class="compact-content">
        <% if phase_method[:trine].present? %>
          <% term = phase_method_text.get_message("trine.#{phase_method[:trine]}") %>
          <div class="info-row"><%= natal_phase_button(term) %></div>
        <% end %>
        <% if phase_method[:half_trine].present? %>
          <% term = phase_method_text.get_message("half_trine.#{phase_method[:half_trine][:key]}") %>
          <div class="info-row"><%= natal_phase_button(term) %> - <%= phase_method_text.get_message("branch_pairs.#{phase_method[:half_trine][:pairs].join('_and_')}") %></div>
        <% end %>
        <% if phase_method[:combination].present? %>
          <% term = phase_method_text.get_message("combination.#{phase_method[:combination][:key]}") %>
          <div class="info-row"><%= natal_phase_button(term) %> - <%= phase_method_text.get_message("branch_pairs.#{phase_method[:combination][:pairs].join('_and_')}") %></div>
        <% end %>
        <% if phase_method[:directional].present? %>
          <% term = phase_method_text.get_message("directional.#{phase_method[:directional]}") %>
          <div class="info-row"><%= natal_phase_button(term) %></div>
        <% end %>
        <% if phase_method[:half_directional].present? %>
          <% term = phase_method_text.get_message("half_directional.#{phase_method[:half_directional][:key]}") %>
          <div class="info-row"><%= natal_phase_button(term) %> - <%= phase_method_text.get_message("branch_pairs.#{phase_method[:half_directional][:pairs].join('_and_')}") %></div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if phase_method[:has_scattered] %>
    <div class="compact-section">
      <div class="compact-header scattered-bg"><i class="fas fa-share-alt"></i> 位相（散法）</div>
      <div class="compact-content">
        <% if phase_method[:clash].present? %>
          <% term = phase_method_text.get_message("clash.#{phase_method[:clash][:key]}") %>
          <div class="info-row"><%= natal_phase_button(term) %> - <%= phase_method_text.get_message("branch_pairs.#{phase_method[:clash][:pairs].join('_and_')}") %></div>
        <% end %>
        <% if phase_method[:harm].present? %>
          <% phase_method[:harm].each do |harm_obj| %>
            <% term = "害（#{harm_obj.keys.first}）" %>
            <div class="info-row"><%= natal_phase_button(term) %></div>
          <% end %>
        <% end %>
        <% if phase_method[:punishment].present? %>
          <% phase_method[:punishment][:pairs].each do |pair| %>
            <% term = phase_method_text.get_message("punishment.#{phase_method[:punishment][:key]}") %>
            <div class="info-row"><%= natal_phase_button(term) %> - <%= phase_method_text.get_message("branch_pairs.#{pair.join('_and_')}") %></div>
          <% end %>
        <% end %>
        <% if phase_method[:self_punishment].present? %>
          <% phase_method[:self_punishment][:pairs].each do |pair| %>
            <% term = phase_method_text.get_message("self_punishment.#{phase_method[:self_punishment][:key]}") %>
            <div class="info-row"><%= natal_phase_button(term) %> - <%= phase_method_text.get_message("branch_pairs.#{pair.join('_and_')}") %></div>
          <% end %>
        <% end %>
        <% if phase_method[:braking].present? %>
          <% phase_method[:braking].each do |braking_obj| %>
            <% term = "破（#{braking_obj.keys.first}）" %>
            <div class="info-row"><%= natal_phase_button(term) %></div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if phase_method[:has_special] %>
    <div class="compact-section">
      <div class="compact-header special-bg"><i class="fas fa-magic"></i> 位相（特殊）</div>
      <div class="compact-content">
        <% if phase_method[:strong_half_trine].present? %>
          <% term = phase_method_text.get_message('strong_half_trine') %>
          <div class="info-row"><%= natal_phase_button(term) %></div>
        <% end %>
        <% if phase_method[:ricchin].present? %>
          <% phase_method[:ricchin][:pairs].each do |pair| %>
            <div class="info-row"><%= natal_phase_button('律音') %> - <%= phase_method_text.get_message("branch_pairs.#{pair.join('_and_')}") %></div>
          <% end %>
        <% end %>
        <% if phase_method[:nacchin].present? %>
          <% phase_method[:nacchin][:pairs].each do |pair| %>
            <div class="info-row"><%= natal_phase_button('納音') %> - <%= phase_method_text.get_message("branch_pairs.#{pair.join('_and_')}") %></div>
          <% end %>
        <% end %>
        <% if phase_method[:dual_clash].present? %>
          <% phase_method[:dual_clash][:pairs].each do |pair| %>
            <div class="info-row"><%= natal_phase_button('天剋地冲', '天剋地中') %> - <%= phase_method_text.get_message("branch_pairs.#{pair.join('_and_')}") %></div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
  <% if phase_method[:has_combined] && phase_method[:has_scattered] %>
    <div class="compact-section">
      <div class="compact-header special-bg"><i class="fas fa-balance-scale"></i> 位相（複合）</div>
      <div class="compact-content">
        <div class="info-row"><%= natal_phase_button('合法と散法の同居') %></div>
      </div>
    </div>
  <% end %>
  <%= render 'fortune_analysis/natal_phase_side_panel' %>
</div>
