<aside class="abnormal-panel" data-abnormal-panel-target="panel" aria-hidden="true" aria-label="異常干支の解説">
  <button type="button" class="abnormal-panel-close" data-action="abnormal-panel#close" aria-label="閉じる">
    <i class="fas fa-xmark"></i>
  </button>

  <div class="abnormal-panel-kicker">異常干支</div>
  <div class="abnormal-panel-heading">
    <span class="abnormal-panel-term" data-abnormal-panel-target="term"></span>
    <span class="abnormal-panel-category" data-abnormal-panel-target="category"></span>
  </div>

  <section class="abnormal-panel-section">
    <h3>概要</h3>
    <p data-abnormal-panel-target="short"></p>
  </section>

  <section class="abnormal-panel-section">
    <h3>詳細</h3>
    <p data-abnormal-panel-target="detail"></p>
  </section>
</aside>
