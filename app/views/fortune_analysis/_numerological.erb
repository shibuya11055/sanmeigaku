<div class="numerological" data-controller="health-panel">
  <% if local_assigns[:numerological_health].present? %>
    <div class="numerological-toolbar">
      <div class="numerological-toolbar-title">数理法</div>
      <button type="button" class="health-panel-trigger" data-action="health-panel#open" aria-haspopup="dialog">
        <i class="fas fa-notes-medical"></i>
        健康を見る
      </button>
    </div>
  <% end %>

  <table>
    <thead>
      <tr>
        <th>気</th>
        <th><%= day_branch.name %></th>
        <th><%= month_branch.name %></th>
        <th><%= year_branch.name %></th>
        <th>点数<br/>合計</th>
        <th>干数<br/>合計</th>
        <th>全点<br/>数計</th>
        <th>星</th>
        <th>割合<br/>(%)</th>
        <th>五行<br/>(%)</th>
      </tr>
    </thead>
    <tbody>
      <% numerological.each_with_index do |(key, value), index| %>
        <tr>
          <td><%= key %></td>
          <td><%= value[:day_branch_point] %></td>
          <td><%= value[:month_branch_point] %></td>
          <td><%= value[:year_branch_point] %></td>
          <td><%= value[:point_sum] %></td>
          <td><%= value[:stem_count] %></td>
          <td><%= value[:all_points] %></td>
          <td><%= value[:ten_major_star].name %></td>
          <td><%= value[:percentage] %></td>
          <% if index.even? %>
            <td rowspan="2"><%= simple_format(value[:element_percentage]) %></td>
          <% end %>
        </tr>
      <% end %>
      <tr>
          <td colspan="6"></td>
          <td><%= total_energy %></td>
          <td colspan="3"></td>
      </tr>
    </tbody>
  </table>

  <% if local_assigns[:numerological_health].present? %>
    <%= render 'fortune_analysis/numerological_health_side_panel', numerological_health: numerological_health %>
  <% end %>
</div>
