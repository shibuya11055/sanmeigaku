<aside class="energy-panel" data-energy-panel-target="panel" aria-hidden="true" aria-label="三期エネルギーの解説">
  <button type="button" class="energy-panel-close" data-action="energy-panel#close" aria-label="閉じる">
    <i class="fas fa-xmark"></i>
  </button>

  <div class="energy-panel-kicker">三期エネルギー</div>
  <div class="energy-panel-heading">
    <span class="energy-panel-term" data-energy-panel-target="term"></span>
    <span class="energy-panel-meta">
      <span data-energy-panel-target="reading"></span>
      <span data-energy-panel-target="period"></span>
      <span>パワー: <span data-energy-panel-target="power"></span></span>
    </span>
  </div>

  <section class="energy-panel-section">
    <h3>概要</h3>
    <p data-energy-panel-target="short"></p>
  </section>

  <section class="energy-panel-section">
    <h3>基本特徴</h3>
    <p data-energy-panel-target="basic"></p>
  </section>

  <section class="energy-panel-section">
    <h3 data-energy-panel-target="periodHeading"></h3>
    <p data-energy-panel-target="periodText"></p>
  </section>
</aside>
