<div data-controller="relationship-panel yearly-fortune-panel">
  <div class="yearly-fortune">
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>年（年齢）</th>
          <th>干支</th>
          <th>主星</th>
          <th>従星</th>
          <th>日</th>
          <th>月</th>
          <th>年</th>
          <th>天中殺</th>
        </tr>
      </thead>
      <tbody>
        <% yearly_fortune.each do |item| %>
          <%= tag.tr(**yearly_fortune_row_options(item)) do %>
            <td><%= item[:year_and_age] %></td>
            <td><%= item[:stem_and_branch] %></td>
            <td><%= item[:major_star] %></td>
            <td><%= item[:sub_star] %></td>
            <%= relationship_color(item[:relationship][:day], item[:heavenly_void]) %>
            <%= relationship_color(item[:relationship][:month], item[:heavenly_void]) %>
            <%= relationship_color(item[:relationship][:year], item[:heavenly_void]) %>
            <%= relationship_color(item[:heavenly_void], item[:heavenly_void]) %>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
  <%= render 'fortune_analysis/relationship_side_panel' %>
  <%= render 'fortune_analysis/yearly_fortune_side_panel' %>
</div>
