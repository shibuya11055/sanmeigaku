<aside class="natal-phase-panel" data-natal-phase-panel-target="panel" aria-hidden="true" aria-label="宿命位相法の解説">
  <button type="button" class="natal-phase-panel-close" data-action="natal-phase-panel#close" aria-label="閉じる">
    <i class="fas fa-xmark"></i>
  </button>

  <div class="natal-phase-panel-kicker">宿命位相法</div>
  <div class="natal-phase-panel-heading">
    <span class="natal-phase-panel-term" data-natal-phase-panel-target="term"></span>
    <span class="natal-phase-panel-category" data-natal-phase-panel-target="category"></span>
  </div>

  <section class="natal-phase-panel-section">
    <h3>概要</h3>
    <p data-natal-phase-panel-target="short"></p>
  </section>

  <section class="natal-phase-panel-section">
    <h3>詳細</h3>
    <p data-natal-phase-panel-target="detail"></p>
  </section>
</aside>
