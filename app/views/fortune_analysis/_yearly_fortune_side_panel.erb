<% panel_label = local_assigns.fetch(:panel_label, '年運読み解き') %>

<aside class="yearly-fortune-panel" data-yearly-fortune-panel-target="panel" aria-hidden="true" aria-label="<%= panel_label %>">
  <button type="button" class="yearly-fortune-panel-close" data-action="yearly-fortune-panel#close" aria-label="閉じる">
    <i class="fas fa-xmark"></i>
  </button>

  <div class="yearly-fortune-panel-kicker"><%= panel_label %></div>
  <div class="yearly-fortune-panel-heading">
    <div>
      <span class="yearly-fortune-panel-year" data-yearly-fortune-panel-target="year"></span>
      <span class="yearly-fortune-panel-cycle" data-yearly-fortune-panel-target="stemAndBranch"></span>
    </div>
    <span class="yearly-fortune-panel-void" data-yearly-fortune-panel-target="voidLabel"></span>
  </div>

  <section class="yearly-fortune-panel-section">
    <h3>全体像</h3>
    <p data-yearly-fortune-panel-target="summary"></p>
  </section>

  <section class="yearly-fortune-panel-section">
    <h3>主星テーマ</h3>
    <div class="yearly-fortune-panel-meta">
      <span data-yearly-fortune-panel-target="majorStar"></span>
      <span data-yearly-fortune-panel-target="majorKeywords"></span>
    </div>
    <p class="yearly-fortune-panel-people">
      主人物: <span data-yearly-fortune-panel-target="keyPeople"></span>
    </p>
    <p class="yearly-fortune-panel-people">
      補助的に見る人物: <span data-yearly-fortune-panel-target="placePeople"></span>
    </p>
    <p data-yearly-fortune-panel-target="majorText"></p>
  </section>

  <section class="yearly-fortune-panel-section">
    <h3>従星エネルギー</h3>
    <div class="yearly-fortune-panel-meta">
      <span data-yearly-fortune-panel-target="subStar"></span>
      <span>パワー: <span data-yearly-fortune-panel-target="subPower"></span></span>
      <span data-yearly-fortune-panel-target="subKeywords"></span>
    </div>
    <p data-yearly-fortune-panel-target="subText"></p>
  </section>

  <section class="yearly-fortune-panel-section">
    <h3>位相の出方</h3>
    <p data-yearly-fortune-panel-target="dayRelationship"></p>
    <p data-yearly-fortune-panel-target="monthRelationship"></p>
    <p data-yearly-fortune-panel-target="yearRelationship"></p>
  </section>

  <section class="yearly-fortune-panel-section">
    <h3>天中殺</h3>
    <p data-yearly-fortune-panel-target="voidText"></p>
  </section>

  <section class="yearly-fortune-panel-section">
    <h3>健康注意</h3>
    <div class="yearly-fortune-panel-meta">
      <span data-yearly-fortune-panel-target="healthChips"></span>
      <span class="yearly-fortune-panel-health" data-yearly-fortune-panel-target="healthLabel"></span>
    </div>
    <p data-yearly-fortune-panel-target="healthSummary"></p>
    <p data-yearly-fortune-panel-target="healthDetail"></p>
  </section>
</aside>
