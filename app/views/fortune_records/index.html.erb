<% content_for :title, "占いカルテ一覧 | Unilo" %>

<div class="records-container">
  <header class="header-section">
    <h1 class="heading">占いカルテ一覧</h1>
  </header>

  <% if @fortune_records.empty? %>
    <div class="empty-message-container">
      <div class="empty-message-icon">
        <i class="fas fa-file-alt fa-3x" style="color: #bbb;"></i>
      </div>
      <div class="empty-message-text">
        <strong>まだカルテが登録されていません。</strong><br>
        <span>
          カルテを作成するには
          <strong><%= link_to '顧客管理', clients_path %></strong>
          から顧客詳細画面に入り、<br>
          「カルテ作成」ボタンで新規カルテを登録してください。
        </span>
      </div>
    </div>
  <% else %>
    <div class="record-list">
      <table class="record-table">
        <thead>
          <tr>
            <th>顧客名</th>
            <th>相談内容カテゴリ</th>
            <th>相談手段</th>
            <th>開始日時</th>
            <th>終了日時</th>
            <th>金額</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          <% @fortune_records.each do |record| %>
            <tr>
              <td class="record-name">
                <%= link_to record.client.fullname, client_path(record.client) %>
              </td>
              <td><%= record.category_label %></td>
              <td><%= record.consultation_method_label %></td>
              <td><%= record.start_at.strftime('%Y/%m/%d %H:%M') %></td>
              <td><%= record.end_at.strftime('%Y/%m/%d %H:%M') %></td>
              <td><%= number_to_currency(record.amount, unit: '¥', format: "%u%n") %></td>
              <td class="actions-cell">
                <%= link_to fortune_record_path(record), class: "action-btn view-btn", title: "詳細" do %>
                  <i class="fas fa-eye"></i>
                <% end %>
                <%= link_to edit_fortune_record_path(record), class: "action-btn edit-btn", title: "編集" do %>
                  <i class="fas fa-edit"></i>
                <% end %>
                <%= link_to fortune_record_path(record),
                      data: { turbo_method: :delete, turbo_confirm: "本当にこのカルテを削除しますか？" },
                      class: "action-btn delete-btn",
                      title: "削除" do %>
                  <i class="fas fa-trash-alt"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>

<style>
.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}
.heading {
  font-size: 24px;
  margin: 0;
}
.back-btn {
  min-width: 160px;
  height: 44px;
  font-size: 1rem;
  font-weight: 600;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: #f3f4f6;
  color: #333;
  gap: 8px;
}
.record-table {
  width: 100%;
  border-collapse: collapse;
}
.record-table th, .record-table td {
  padding: 12px 16px;
  border-bottom: 1px solid #eee;
  text-align: left;
}
.record-table th {
  background: #f8f9fa;
  color: #444;
  font-weight: bold;
}
.record-name a {
  color: #1a73e8;
  font-weight: bold;
  text-decoration: none;
}
.actions-cell {
  display: flex;
  gap: 8px;
}
.action-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  margin-right: 8px;
  text-decoration: none;
}
.action-btn.view-btn {
  background-color: #e6f3ff;
  color: #1a73e8;
}
.action-btn.edit-btn {
  background-color: #e8f5e9;
  color: #43a047;
}
.action-btn.delete-btn {
  background-color: #fee8e7;
  color: #f44336;
}
.empty-message-container {
  text-align: center;
  margin: 60px 0;
}
.empty-message-icon {
  margin-bottom: 12px;
}
.empty-message-text {
  color: #666;
  font-size: 16px;
}
</style>
